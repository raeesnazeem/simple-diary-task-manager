{
  "name": "simple-diary-task-manager",
  "version": "1.0.0",
  "description": "Minimalistic Desktop Diary and Task Manager",
  "main": "main.js",
  "scripts": {
    "dev": "next dev -p 3004",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently \"next dev -p 3004\" \"wait-on http://localhost:3004 && electron .\"",
    "electron:build": "npm run build && electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raeesnazeem/simple-diary-task-manager.git"
  },
  "build": {
    "appId": "com.raeesnazeem.simplediary",
    "productName": "itsNoted",
    "files": [
      "main.js",
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/appstore.png",
      "target": [
        "dmg"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "raeesnazeem",
      "repo": "simple-diary-task-manager"
    }
  },
  "dependencies": {
    "@types/prismjs": "^1.26.6",
    "date-fns": "^3.3.1",
    "electron-serve": "^2.1.1",
    "lucide-react": "^0.344.0",
    "next": "14.1.3",
    "prismjs": "^1.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-simple-code-editor": "^0.14.1",
    "uuid": "^9.0.1",
    "zundo": "^2.3.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  }
}
